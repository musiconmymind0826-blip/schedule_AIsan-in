  ];
  for(let off=-14;off<=14;off++){
    const d=addD(now,off);if(isWknd(d))continue;
    const seed=d.getDate()*7+d.getMonth()*31;const cnt=5+(seed%5);const used=new Set();
    for(let i=0;i<cnt;i++){
      const ti=(seed*(i+1)*13+i*7)%tpl.length;if(used.has(ti))continue;used.add(ti);
      const T=tpl[ti];const si=(seed+i*3)%STAFF.length;
