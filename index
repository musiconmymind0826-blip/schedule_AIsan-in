// ═══ 案1: AI CHAT ═══════════════════════════════════════
function AIChat({isOpen,onClose,events,onAddEvent,onUpdateStats}){
  const [msgs,setMsgs]=useState([{role:"ai",text:"こんにちは！オロチです🐉 スケジュールについて何でも聞いてください！\n\n例：「来週の空き時間は？」「明日の予定を教えて」"}]);
  const [input,setInput]=useState("");
  const [loading,setLoading]=useState(false);
  const endRef=useRef(null);
  useEffect(()=>{endRef.current?.scrollIntoView({behavior:"smooth"})},[msgs]);

  const send=async()=>{
    if(!input.trim()||loading)return;
    const q=input.trim();setInput("");
    setMsgs(p=>[...p,{role:"user",text:q}]);setLoading(true);
    onUpdateStats(s=>({...s,chatUsed:(s.chatUsed||0)+1}));

    // Local intelligence
    const now=new Date();const todayEvts=events.filter(e=>same(e.start,now)).sort((a,b)=>a.start-b.start);
    const tomorrowEvts=events.filter(e=>same(e.start,addD(now,1))).sort((a,b)=>a.start-b.start);
    const weekEvts=events.filter(e=>{const diff=(e.start-now)/(86400000);return diff>=0&&diff<7;});

    let response="";
    if(q.includes("今日")||q.includes("本日")){
      response=todayEvts.length===0?"今日の予定はありません🎉 ゆっくりできますね！":`今日は${todayEvts.length}件の予定があります：\n\n${todayEvts.map(e=>`⏰ ${fmtT(e.start)} ${e.title}（${STAFF.find(s=>s.id===e.staffId)?.name}）`).join("\n")}`;
    }else if(q.includes("明日")){
      response=tomorrowEvts.length===0?"明日の予定はまだありません。新しい予定を追加しますか？":`明日は${tomorrowEvts.length}件：\n\n${tomorrowEvts.map(e=>`⏰ ${fmtT(e.start)} ${e.title}`).join("\n")}`;
    }else if(q.includes("空き")||q.includes("空いて")){
      const busy=new Set();todayEvts.forEach(e=>{for(let h=e.start.getHours();h<e.end.getHours();h++)busy.add(h)});
      const free=[];for(let h=9;h<18;h++)if(!busy.has(h))free.push(`${h}:00`);
      response=free.length>0?`今日の空き時間：\n\n${free.map(t=>`✅ ${t}〜`).join("\n")}\n\n予定を入れましょうか？`:"今日はかなり詰まっています💦 明日の空きを確認しましょうか？";
    }else if(q.includes("忙しい")||q.includes("負荷")){
      const counts=STAFF.map(s=>({...s,count:weekEvts.filter(e=>e.staffId===s.id).length})).sort((a,b)=>b.count-a.count);
      response=`📊 今週のスタッフ稼働状況：\n\n${counts.map((s,i)=>`${i===0?"🔴":"⚪"} ${s.name}：${s.count}件`).join("\n")}\n\n${counts[0].name}さんが一番忙しいです。タスクの分散を検討しましょうか？`;
    }else if(q.includes("天気")){
      const w=WEATHER_DATA[fmt(now)];
      response=w?`今日の山陰地方の天気：${w.icon} ${w.desc}（${w.temp}°C）\n湿度：${w.humidity}%\n\n${w.icon.includes("🌧")?"☔ 外出の予定がある方は傘をお忘れなく！":"お出かけ日和ですね！"}`:"天気情報を取得できませんでした";
    }else if(q.includes("お客")||q.includes("顧客")||q.includes("カルテ")){
