    {t:"ランチ休憩",tp:"break_t",h:12,m:0,dur:60},{t:"コードレビュー",tp:"task",h:16,m:0,dur:60},
    {t:"営業報告書作成",tp:"task",h:15,m:30,dur:60},{t:"マーケ戦略会議",tp:"meeting",h:14,m:30,dur:60},
    {t:"C社提案準備",tp:"task",h:10,m:0,dur:90,cust:"c3"},{t:"週次レポート",tp:"task",h:17,m:0,dur:30},
