// ═══ 案10: AI OPTIMIZATION ══════════════════════════════
function AIOptimization({isOpen,onClose,events}){
  if(!isOpen)return null;
  const now=new Date();
  const weekEvts=events.filter(e=>{const d=(e.start-now)/86400000;return d>=0&&d<7&&!isWknd(e.start);}).sort((a,b)=>a.start-b.start);

  // 分析ロジック
  const suggestions=[];

  // 訪問の最適化
  const visits=weekEvts.filter(e=>e.type==="visit");
  const visitDays={};visits.forEach(v=>{const k=fmt(v.start);if(!visitDays[k])visitDays[k]=[];visitDays[k].push(v);});
  Object.entries(visitDays).forEach(([day,vs])=>{
    if(vs.length>=2){
      const gap=Math.abs(vs[1].start-vs[0].end)/3600000;
      if(gap>2)suggestions.push({icon:"🚗",type:"移動最適化",text:`${new Date(day).toLocaleDateString("ja-JP",{weekday:"short",month:"short",day:"numeric"})}に訪問が${vs.length}件ありますが、間に${gap.toFixed(0)}時間の空きがあります。連続にすれば移動時間を削減できます。`,priority:"high"});
    }
  });

  // 会議集中日の検出
  const meetingDays={};weekEvts.filter(e=>e.type==="meeting"||e.type==="online").forEach(e=>{const k=fmt(e.start);meetingDays[k]=(meetingDays[k]||0)+1;});
  Object.entries(meetingDays).forEach(([day,cnt])=>{
    if(cnt>=4)suggestions.push({icon:"📅",type:"会議分散",text:`${new Date(day).toLocaleDateString("ja-JP",{weekday:"short",month:"short",day:"numeric"})}に会議が${cnt}件集中しています。一部を別の日に移動して集中作業時間を確保しませんか？`,priority:"medium"});
  });

  // スタッフ負荷の偏り
  const staffLoad=STAFF.map(s=>({...s,count:weekEvts.filter(e=>e.staffId===s.id).length}));
  const maxLoad=Math.max(...staffLoad.map(s=>s.count));
  const minLoad=Math.min(...staffLoad.map(s=>s.count));
  if(maxLoad-minLoad>=5){
    const busiest=staffLoad.find(s=>s.count===maxLoad);
    const lightest=staffLoad.find(s=>s.count===minLoad);
    suggestions.push({icon:"⚖️",type:"負荷分散",text:`${busiest.name}さん(${maxLoad}件)と${lightest.name}さん(${minLoad}件)で負荷に差があります。タスクの振り分けを見直しましょう。`,priority:"high"});
  }

  // 空き時間の提案
  const allBusy=new Set();weekEvts.forEach(e=>{const k=fmt(e.start)+"-"+e.start.getHours();allBusy.add(k);});
  const freeSlots=[];
  for(let d=0;d<5;d++){
    const date=addD(now,d);if(isWknd(date))continue;
    let consecutive=0;
    for(let h=9;h<18;h++){if(!allBusy.has(fmt(date)+"-"+h))consecutive++;else{if(consecutive>=3)freeSlots.push({date,hours:consecutive});consecutive=0;}}
    if(consecutive>=3)freeSlots.push({date,hours:consecutive});
  }
  if(freeSlots.length>0){
    const best=freeSlots.sort((a,b)=>b.hours-a.hours)[0];
    suggestions.push({icon:"💡",type:"集中タイム提案",text:`${best.date.toLocaleDateString("ja-JP",{weekday:"short",month:"short",day:"numeric"})}に${best.hours}時間の空きブロックがあります。集中作業やチーム定例に最適です！`,priority:"low"});
  }

  if(suggestions.length===0)suggestions.push({icon:"✅",type:"最適化済み",text:"今週のスケジュールはバランスが取れています！このまま進めましょう。",priority:"none"});

  const priColors={high:"#e11d48",medium:"#f59e0b",low:"#0066ff",none:"#059669"};
  const priLabels={high:"重要",medium:"推奨",low:"提案",none:"良好"};

  return <div style={OVL} onClick={onClose}>
    <div style={{...MOD,maxWidth:480}} onClick={e=>e.stopPropagation()}>
      <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:18}}>
        <Dragon s={36} level={2}/>
        <div><div style={{fontSize:18,fontWeight:900,color:"#1a1a2e"}}>🧠 AI最適化提案</div><div style={{fontSize:12,color:"#64748b"}}>オロチが今週のスケジュールを分析しました</div></div>
        <button onClick={onClose} style={{...XB,marginLeft:"auto"}}>✕</button>
      </div>

      {suggestions.map((s,i)=><div key={i} style={{padding:14,background:"#f8fafc",borderRadius:12,marginBottom:10,borderLeft:`4px solid ${priColors[s.priority]}`}}>
        <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:6}}>
          <span style={{fontSize:18}}>{s.icon}</span>
          <span style={{fontSize:13,fontWeight:800,color:"#1a1a2e"}}>{s.type}</span>
          <span style={{fontSize:10,padding:"2px 8px",borderRadius:6,fontWeight:700,background:`${priColors[s.priority]}15`,color:priColors[s.priority],marginLeft:"auto"}}>{priLabels[s.priority]}</span>
        </div>
        <div style={{fontSize:13,color:"#475569",lineHeight:1.6}}>{s.text}</div>
      </div>)}
    </div>
  </div>;
}

