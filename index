// ═══ VOICE INPUT ════════════════════════════════════════
function VoiceInput({isOpen,onClose,onCreated,onUpdateStats}){
  const [phase,setPhase]=useState("idle");const [txt,setTxt]=useState("");const [parsed,setParsed]=useState(null);const [err,setErr]=useState("");const rec=useRef(null);
  const reset=()=>{setPhase("idle");setTxt("");setParsed(null);setErr("");};
  useEffect(()=>{if(!isOpen){if(rec.current)try{rec.current.stop()}catch{};rec.current=null;reset();}},[isOpen]);

  const startR=()=>{setErr("");setTxt("");try{
    const SR=window.SpeechRecognition||window.webkitSpeechRecognition;if(!SR){setErr("音声認識非対応。Chrome推奨");return;}
    const r=new SR();r.lang="ja-JP";r.interimResults=true;try{r.continuous=true}catch{}
    r.onresult=e=>{let t="";for(let i=0;i<e.results.length;i++)t+=e.results[i][0].transcript;setTxt(t)};
    r.onerror=e=>{if(e.error==="not-allowed")setErr("マイクを許可してください");else if(e.error!=="aborted")setErr(`エラー: ${e.error}`)};
    r.onend=()=>setPhase(p=>{if(p==="listening"&&rec.current){try{rec.current.start();return"listening"}catch{return"transcribed"}}return p});
    r.start();rec.current=r;setPhase("listening");onUpdateStats(s=>({...s,voiceUsed:(s.voiceUsed||0)+1}));
  }catch{setErr("音声認識を開始できません")}};

  const stopR=()=>{if(rec.current){try{rec.current.stop()}catch{};rec.current=null}setPhase(txt?"transcribed":"idle")};

  const parseAI=async()=>{if(!txt.trim())return;setPhase("parsing");
    try{const now=new Date();
      const res=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},
        body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1000,messages:[{role:"user",content:`スケジュール解析AI。JSONのみ返答。現在:${now.toISOString()} JST。スタッフ:${STAFF.map(s=>`${s.name}(${s.id})`).join(",")}。入力:「${txt}」。JSON:{"title":"","date":"YYYY-MM-DD","startTime":"HH:MM","endTime":"HH:MM","staffId":"s1","type":"meeting|visit|call|task|break_t|online","description":""}`}]})});
      const data=await res.json();setParsed(JSON.parse((data.content?.[0]?.text||"").replace(/```json|```/g,"").trim()));setPhase("parsed");
    }catch{fallback()}};

  const fallback=()=>{const now=new Date();let title="新規予定",type="meeting";
    if(txt.includes("会議"))title="チーム会議";else if(txt.includes("訪問")){title="訪問";type="visit";}else if(txt.includes("電話")){title="電話";type="call";}else title=txt.slice(0,20)||"新規予定";
    const tm=txt.match(/(\d{1,2})[時じ:：]/);const h=tm?parseInt(tm[1]):10;const d=txt.includes("明日")?addD(now,1):now;
    let si="s1";for(const s of STAFF)if(txt.includes(s.name.split(" ")[0])){si=s.id;break;}
    setParsed({title,date:fmt(d),startTime:`${String(h).padStart(2,"0")}:00`,endTime:`${String(h+1).padStart(2,"0")}:00`,staffId:si,type,description:`音声: ${txt}`});setPhase("parsed");};

  const confirmEv=()=>{if(!parsed)return;const [y,mo,d]=parsed.date.split("-").map(Number);const [sh,sm]=parsed.startTime.split(":").map(Number);const [eh,em]=parsed.endTime.split(":").map(Number);
    onCreated({id:uid(),title:parsed.title,type:parsed.type||"meeting",staffId:parsed.staffId||"s1",desc:parsed.description||"",customerId:null,resourceId:null,start:new Date(y,mo-1,d,sh,sm),end:new Date(y,mo-1,d,eh,em),synced:false});onClose();};

  if(!isOpen)return null;
  return <div style={OVL} onClick={onClose}><div style={{...MOD,maxWidth:460}} onClick={e=>e.stopPropagation()}>
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
      <div style={{display:"flex",alignItems:"center",gap:8}}><Dragon s={34}/><div><div style={{fontSize:17,fontWeight:900}}>音声スケジュール入力</div><div style={{fontSize:11,color:"#94a3b8"}}>AIが自然な言葉から予定を自動作成</div></div></div>
      <button onClick={onClose} style={XB}>✕</button>
    </div>
    <div style={{textAlign:"center",padding:"16px 0"}}>
      {phase==="idle"&&<><button onClick={startR} onTouchEnd={e=>{e.preventDefault();startR()}} style={{width:88,height:88,borderRadius:"50%",border:"none",cursor:"pointer",background:"linear-gradient(135deg,#0066ff,#3b82f6)",color:"#fff",fontSize:34,boxShadow:"0 8px 30px rgba(0,102,255,.35)",WebkitTapHighlightColor:"transparent"}}>🎤</button><div style={{marginTop:10,fontSize:13,color:"#64748b"}}>タップで録音開始</div></>}
      {phase==="listening"&&<><button onClick={stopR} onTouchEnd={e=>{e.preventDefault();stopR()}} style={{width:88,height:88,borderRadius:"50%",border:"none",cursor:"pointer",background:"linear-gradient(135deg,#e11d48,#f43f5e)",color:"#fff",fontSize:34,animation:"pulseRing 1.5s infinite",WebkitTapHighlightColor:"transparent"}}>⏹</button><div style={{marginTop:10,fontSize:13,color:"#e11d48",fontWeight:700}}>🔴 録音中...</div>{txt&&<div style={{marginTop:12,padding:"10px 14px",borderRadius:12,background:"#f8fafc",border:"1px dashed #cbd5e1",fontSize:14,color:"#475569"}}>「{txt}」</div>}</>}
    </div>
    {(phase==="transcribed"||phase==="parsing")&&<div style={{background:"#f8fafc",borderRadius:12,padding:14,marginBottom:10,border:"1px solid #e2e8f0"}}>
      <div style={{fontSize:15,color:"#1a1a2e",fontWeight:500,marginBottom:10}}>「{txt}」</div>
      <div style={{display:"flex",gap:8}}><button onClick={parseAI} disabled={phase==="parsing"} style={{...BP,flex:1,background:phase==="parsing"?"#94a3b8":"linear-gradient(135deg,#8b5cf6,#a855f7)"}}>{phase==="parsing"?"解析中...":"✨ AIで自動作成"}</button><button onClick={reset} style={BS}>🔄</button></div>
    </div>}
    {phase==="parsed"&&parsed&&<div style={{background:"#ecfdf5",borderRadius:12,padding:14,border:"2px solid #22c55e",marginBottom:8}}>
      <div style={{fontSize:14,fontWeight:800,color:"#059669",marginBottom:10}}>✅ 解析完了</div>
      {[["タイトル",parsed.title],["日時",`${parsed.date} ${parsed.startTime}-${parsed.endTime}`],["担当",STAFF.find(s=>s.id===parsed.staffId)?.name||"未指定"],["種類",`${CATS[parsed.type]?.icon||""} ${CATS[parsed.type]?.label||parsed.type}`]].map(([k,v])=><div key={k} style={{display:"flex",gap:8,fontSize:13,marginBottom:4}}><span style={{color:"#64748b",minWidth:52,fontWeight:700}}>{k}</span><span style={{fontWeight:600}}>{v}</span></div>)}
      <div style={{display:"flex",gap:8,marginTop:12}}><button onClick={confirmEv} style={{...BP,flex:1,background:"linear-gradient(135deg,#059669,#10b981)",borderRadius:10}}>✅ 登録</button><button onClick={reset} style={BS}>やり直す</button></div>
    </div>}
    {err&&<div style={{padding:"8px 12px",borderRadius:10,background:"#FEF2F2",color:"#DC2626",fontSize:13,marginTop:6}}>{err}</div>}
    {phase==="idle"&&<div style={{padding:"10px 12px",background:"#f8fafc",borderRadius:10,marginTop:6}}>
      <div style={{fontSize:11,color:"#94a3b8",fontWeight:700,marginBottom:6}}>💡 タップで入力例を使用</div>
      {["明日10時からチーム会議","佐藤さんとA社訪問を14時に","今日16時からコードレビュー1時間"].map(ex=><div key={ex} onClick={()=>{setTxt(ex);setPhase("transcribed")}} style={{fontSize:12,color:"#0066ff",padding:"4px 0",cursor:"pointer",borderBottom:"1px solid #f1f5f9"}}>「{ex}」</div>)}
    </div>}
  </div></div>;
}

