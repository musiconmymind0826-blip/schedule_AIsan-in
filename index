      </div>
      <div style={{display:"flex",alignItems:"center",gap:4}}>
        <div style={{display:"flex",alignItems:"center",gap:3,padding:"3px 8px",borderRadius:16,background:sync==="synced"?"rgba(5,150,105,.15)":"rgba(249,115,22,.15)"}}>
          <div style={{width:6,height:6,borderRadius:"50%",background:sync==="synced"?"#10b981":"#f97316",animation:sync==="syncing"?"pulseRing 1.2s infinite":"none"}}/>
          <span style={{fontSize:9,color:sync==="synced"?"#6ee7b7":"#fdba74",fontWeight:600}}>{sync==="synced"?"同期済":"同期中"}</span>
        </div>
        <button onClick={()=>setShowDash(true)} title="ダッシュボード" style={{background:"rgba(255,255,255,.08)",border:"none",borderRadius:8,padding:"5px 8px",cursor:"pointer",color:"#fff",fontSize:13}}>📊</button>
        <button onClick={()=>setShowOptimize(true)} title="AI最適化" style={{background:"rgba(255,255,255,.08)",border:"none",borderRadius:8,padding:"5px 8px",cursor:"pointer",color:"#fff",fontSize:13}}>🧠</button>
        <button onClick={()=>{setShowAlert(true);updateStats(s=>({...s,alertChecked:(s.alertChecked||0)+1}))}} style={{background:"rgba(255,255,255,.08)",border:"none",borderRadius:8,padding:"5px 8px",cursor:"pointer",color:"#fff",fontSize:13,position:"relative"}}>
          🔔{tCnt>0&&<span style={{position:"absolute",top:-2,right:-2,width:14,height:14,borderRadius:"50%",background:"#e11d48",color:"#fff",fontSize:8,fontWeight:800,display:"flex",alignItems:"center",justifyContent:"center"}}>{tCnt}</span>}
        </button>
      </div>
    </header>

    {/* TOOLBAR */}
    <div style={{background:"#fff",borderBottom:"1px solid #e5e7eb",padding:"6px 10px",display:"flex",flexWrap:"wrap",gap:6,alignItems:"center",justifyContent:"space-between"}}>
      <div style={{display:"flex",alignItems:"center",gap:4}}>
        <button onClick={()=>nav(-1)} style={{background:"#f1f5f9",border:"none",borderRadius:8,padding:"4px 8px",cursor:"pointer",fontSize:13,fontWeight:700,color:"#374151"}}>◀</button>
        <button onClick={()=>setCur(new Date())} style={{background:"#0066ff",border:"none",borderRadius:8,padding:"4px 10px",cursor:"pointer",fontSize:10,fontWeight:700,color:"#fff"}}>今日</button>
        <button onClick={()=>nav(1)} style={{background:"#f1f5f9",border:"none",borderRadius:8,padding:"4px 8px",cursor:"pointer",fontSize:13,fontWeight:700,color:"#374151"}}>▶</button>
        <span style={{fontSize:13,fontWeight:800,color:"#1a1a2e",marginLeft:2,whiteSpace:"nowrap"}}>{hTitle}</span>
      </div>
      <div style={{display:"flex",gap:3,alignItems:"center"}}>
        <button onClick={()=>setShowResources(!showResources)} style={{padding:"4px 8px",borderRadius:6,border:showResources?"2px solid #475569":"1.5px solid #e2e8f0",background:showResources?"#47556910":"#fff",fontSize:10,fontWeight:700,cursor:"pointer",color:showResources?"#475569":"#94a3b8"}}>🏠設備</button>
        {[["day","日"],["week","週"],["month","月"]].map(([k,l])=>
          <button key={k} onClick={()=>setView(k)} style={{padding:"4px 12px",borderRadius:7,border:"none",cursor:"pointer",fontSize:11,fontWeight:700,background:view===k?"#0a0e27":"#f1f5f9",color:view===k?"#fff":"#64748b"}}>{l}</button>
        )}
      </div>
    </div>

    {/* 案3: WEATHER + 案2: HEATMAP */}
    <div style={{background:"#fff",borderBottom:"1px solid #e5e7eb",padding:"4px 12px",display:"flex",gap:8,alignItems:"center",overflowX:"auto"}}>
      <WeatherBar date={cur}/>
      {view==="week"&&<StaffHeatmap events={events} weekDates={wd}/>}
    </div>

    {/* STAFF FILTER */}
    <div style={{background:"#fff",borderBottom:"1px solid #e5e7eb",padding:"5px 10px",display:"flex",gap:4,overflowX:"auto"}}>
      <Chip active={!selStaff} onClick={()=>setSelStaff(null)} color="#0a0e27" label="全員"/>
      {STAFF.map(s=><Chip key={s.id} active={selStaff===s.id} onClick={()=>setSelStaff(selStaff===s.id?null:s.id)} color={s.color} label={s.name}/>)}
    </div>

    {/* CALENDAR BODY */}
    <div style={{padding:"8px 6px 130px",maxWidth:1280,margin:"0 auto"}}>
      {/* WEEK */}
      {view==="week"&&<div style={CD}><div style={{overflowX:"auto"}}><div style={{minWidth:820}}>
        <div style={{display:"grid",gridTemplateColumns:"100px repeat(7,1fr)",borderBottom:"2px solid #e5e7eb"}}>
          <div style={{padding:6,background:"#f8fafc",borderRight:"1px solid #e5e7eb"}}><span style={{fontSize:10,color:"#94a3b8",fontWeight:700}}>スタッフ</span></div>
          {wd.map((d,i)=><div key={i} onClick={()=>{setCur(d);setView("day")}} style={{padding:"4px 2px",textAlign:"center",cursor:"pointer",borderRight:"1px solid #f1f5f9",background:isToday(d)?"#eff6ff":"#f8fafc"}}>
            <div style={{fontSize:10,fontWeight:600,color:d.getDay()===0?"#e11d48":d.getDay()===6?"#0066ff":"#64748b"}}>{WD[d.getDay()]}</div>
            <div style={{fontSize:15,fontWeight:800,width:26,height:26,lineHeight:"26px",borderRadius:"50%",margin:"1px auto",background:isToday(d)?"#0066ff":"transparent",color:isToday(d)?"#fff":d.getDay()===0?"#e11d48":"#1a1a2e"}}>{d.getDate()}</div>
          </div>)}
        </div>
        {vs.map(st=><div key={st.id} style={{display:"grid",gridTemplateColumns:"100px repeat(7,1fr)",borderBottom:"1px solid #f1f5f9",minHeight:66}}>
          <div style={{padding:"6px 4px",borderRight:"1px solid #e5e7eb",display:"flex",alignItems:"center",gap:4,background:"#fafbfc"}}>
            <div style={{width:28,height:28,borderRadius:"50%",background:st.color,flexShrink:0,color:"#fff",fontSize:10,fontWeight:800,display:"flex",alignItems:"center",justifyContent:"center",boxShadow:`0 2px 6px ${st.color}40`}}>{st.avatar}</div>
            <div style={{minWidth:0}}><div style={{fontSize:11,fontWeight:700,color:"#1a1a2e",whiteSpace:"nowrap",overflow:"hidden",textOverflow:"ellipsis"}}>{st.name}</div><div style={{fontSize:9,color:"#94a3b8"}}>{st.role}</div></div>
          </div>
          {wd.map((d,di)=>{const de=eDS(d,st.id);return <div key={di}
            onDrop={e=>handleDrop(d,st.id,e)} onDragOver={handleDragOver} onDragLeave={handleDragLeave}
            onDoubleClick={()=>openNew(d,st.id)} style={{padding:"2px 1px",borderRight:"1px solid #f3f4f6",background:isWknd(d)?"#fafbfc":isToday(d)?"#fafcff":"#fff",minHeight:40}}>
            {de.map(ev=><EvBlock key={ev.id} ev={ev} compact onClick={setSelEv}/>)}
            {de.length===0&&!isWknd(d)&&<div onClick={()=>openNew(d,st.id)} style={{height:"100%",minHeight:28,display:"flex",alignItems:"center",justifyContent:"center",cursor:"pointer",borderRadius:4,color:"transparent",fontSize:10}}
              onMouseEnter={e=>{e.currentTarget.style.background="#f0f4ff";e.currentTarget.style.color="#0066ff"}}
              onMouseLeave={e=>{e.currentTarget.style.background="transparent";e.currentTarget.style.color="transparent"}}>＋</div>}
          </div>;})}
        </div>)}
      </div></div></div>}

      {/* DAY */}
      {view==="day"&&<div style={CD}><div style={{overflowX:"auto"}}><div style={{minWidth:Math.max(400,vs.length*100+80)}}>
        <div style={{display:"grid",gridTemplateColumns:`70px repeat(${vs.length},1fr)`,borderBottom:"2px solid #e5e7eb"}}>
          <div style={{padding:6,background:"#f8fafc",borderRight:"1px solid #e5e7eb"}}><span style={{fontSize:10,color:"#94a3b8",fontWeight:700}}>時間</span></div>
          {vs.map(s=><div key={s.id} style={{padding:"6px 4px",textAlign:"center",background:"#f8fafc",borderRight:"1px solid #f1f5f9"}}>
            <div style={{width:24,height:24,borderRadius:"50%",background:s.color,color:"#fff",fontSize:10,fontWeight:800,display:"inline-flex",alignItems:"center",justifyContent:"center"}}>{s.avatar}</div>
            <div style={{fontSize:10,fontWeight:700,marginTop:1}}>{s.name}</div>
          </div>)}
        </div>
        {Array.from({length:11},(_,i)=>i+8).map(h=><div key={h} style={{display:"grid",gridTemplateColumns:`70px repeat(${vs.length},1fr)`,borderBottom:"1px solid #f1f5f9",minHeight:56}}>
          <div style={{padding:"4px 6px",borderRight:"1px solid #e5e7eb",background:"#fafbfc",fontSize:11,fontWeight:700,color:"#64748b"}}>{String(h).padStart(2,"0")}:00</div>
          {vs.map(s=>{const he=eDS(cur,s.id).filter(e=>e.start.getHours()===h);return <div key={s.id}
            onDrop={e=>{e.preventDefault();e.currentTarget.classList.remove("drag-over");const evId=e.dataTransfer.getData("text/plain");if(!evId)return;
              setEvents(prev=>prev.map(ev=>{if(ev.id!==evId)return ev;const dur=ev.end-ev.start;const ns=new Date(cur.getFullYear(),cur.getMonth(),cur.getDate(),h,0);return{...ev,staffId:s.id,start:ns,end:new Date(ns.getTime()+dur),synced:false}}));notify("📌 移動完了","info");doSync()}}
            onDragOver={handleDragOver} onDragLeave={handleDragLeave}
            onDoubleClick={()=>openNew(cur,s.id)} style={{padding:"2px 3px",borderRight:"1px solid #f3f4f6",background:h===12?"#fefce8":"#fff"}}>
            {he.map(ev=><EvBlock key={ev.id} ev={ev} onClick={setSelEv}/>)}
          </div>;})}
        </div>)}
      </div></div></div>}

      {/* MONTH */}
      {view==="month"&&<div style={CD}>
        <div style={{display:"grid",gridTemplateColumns:"repeat(7,1fr)",borderBottom:"1px solid #e5e7eb"}}>
          {WD.slice(1).concat(WD[0]).map((d,i)=><div key={d} style={{padding:"6px 2px",textAlign:"center",fontSize:11,fontWeight:700,background:"#f8fafc",color:i===5?"#0066ff":i===6?"#e11d48":"#64748b"}}>{d}</div>)}
        </div>
        <div style={{display:"grid",gridTemplateColumns:"repeat(7,1fr)"}}>
          {md.map((d,i)=>{const de=eD(d);const cm=d.getMonth()===cur.getMonth();const w=WEATHER_DATA[fmt(d)];
            return <div key={i} onClick={()=>{setCur(d);setView("day")}} style={{minHeight:72,padding:2,borderRight:"1px solid #f3f4f6",borderBottom:"1px solid #f3f4f6",background:isToday(d)?"#eff6ff":!cm?"#fafbfc":"#fff",cursor:"pointer",opacity:cm?1:.35}}>
              <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"0 2px"}}>
                <div style={{fontSize:11,fontWeight:isToday(d)?800:600,width:22,height:22,lineHeight:"22px",textAlign:"center",borderRadius:"50%",background:isToday(d)?"#0066ff":"transparent",color:isToday(d)?"#fff":d.getDay()===0?"#e11d48":"#374151"}}>{d.getDate()}</div>
                {w&&cm&&<span style={{fontSize:10}}>{w.icon}</span>}
              </div>
              {de.slice(0,2).map(ev=>{const s=STAFF.find(x=>x.id===ev.staffId);return <div key={ev.id} style={{fontSize:8,padding:"1px 3px",borderRadius:3,marginBottom:1,background:s?.color||"#94a3b8",color:"#fff",fontWeight:600,whiteSpace:"nowrap",overflow:"hidden",textOverflow:"ellipsis"}}>{ev.title}</div>})}
              {de.length>2&&<div style={{fontSize:8,color:"#64748b",fontWeight:700}}>+{de.length-2}</div>}
            </div>;})}
        </div>
      </div>}
    </div>

    {/* FABs */}
    <div style={{position:"fixed",bottom:20,right:14,display:"flex",flexDirection:"column",gap:8,zIndex:40}}>
      <button onClick={()=>setShowChat(true)} title="AIチャット" style={{width:48,height:48,borderRadius:"50%",border:"none",background:"linear-gradient(135deg,#059669,#10b981)",color:"#fff",fontSize:18,cursor:"pointer",boxShadow:"0 4px 16px rgba(5,150,105,.4)",display:"flex",alignItems:"center",justifyContent:"center"}}>🐉</button>
      <button onClick={()=>setShowVoice(true)} title="音声入力" style={{width:48,height:48,borderRadius:"50%",border:"none",background:"linear-gradient(135deg,#8b5cf6,#6d28d9)",color:"#fff",fontSize:18,cursor:"pointer",boxShadow:"0 4px 16px rgba(139,92,246,.4)",display:"flex",alignItems:"center",justifyContent:"center"}}>🎤</button>
      <button onClick={()=>openNew()} title="新規予定" style={{width:48,height:48,borderRadius:"50%",border:"none",background:"linear-gradient(135deg,#0066ff,#2563eb)",color:"#fff",fontSize:22,cursor:"pointer",boxShadow:"0 4px 16px rgba(0,102,255,.4)",display:"flex",alignItems:"center",justifyContent:"center"}}>＋</button>
    </div>

    {/* MASCOTS */}
    <div style={{position:"fixed",bottom:4,left:10,zIndex:30,pointerEvents:"none",display:"flex",alignItems:"flex-end",opacity:.8}}>
      <div style={{animation:"bounceY 3s ease-in-out infinite"}}><Sheep s={34} level={Math.min(3,Math.floor((stats.alertChecked||0)/5))}/></div>
      <div style={{animation:"bounceY 3s ease-in-out infinite .4s"}}><Dragon s={38} level={Math.min(3,Math.floor((stats.voiceUsed||0)/3))}/></div>
      <div style={{animation:"bounceY 3s ease-in-out infinite .8s"}}><Camel s={34} level={Math.min(3,Math.floor((stats.chatUsed||0)/5))}/></div>
    </div>

    {/* MODALS */}
    {showAlert&&<MorningAlert events={events} onClose={()=>setShowAlert(false)} stats={stats}/>}
    <EventDetail event={selEv} onClose={()=>setSelEv(null)} onDelete={delEv} onEdit={openEdit} onOpenCustomer={id=>{setShowCustomer(id)}}/>
    <EventForm isOpen={showForm} onClose={()=>{setShowForm(false);setEditEv(null)}} onSave={saveEv} editEvent={editEv} defaultDate={formDef.date} defaultStaff={formDef.staff}/>
    <VoiceInput isOpen={showVoice} onClose={()=>setShowVoice(false)} onCreated={addEv} onUpdateStats={updateStats}/>
    <AIChat isOpen={showChat} onClose={()=>setShowChat(false)} events={events} onAddEvent={addEv} onUpdateStats={updateStats}/>
    <Dashboard isOpen={showDash} onClose={()=>setShowDash(false)} events={events} stats={stats}/>
    <MascotStatus isOpen={showMascot} onClose={()=>setShowMascot(false)} stats={stats}/>
    <AIOptimization isOpen={showOptimize} onClose={()=>setShowOptimize(false)} events={events}/>
    {showCustomer&&<CustomerCard isOpen={!!showCustomer} onClose={()=>setShowCustomer(null)} events={events} customerId={showCustomer}/>}

    {/* TOAST */}
    {toast&&<div style={{position:"fixed",bottom:90,left:"50%",transform:"translateX(-50%)",background:toast.t==="warning"?"#d97706":toast.t==="info"?"#0066ff":"#059669",color:"#fff",padding:"8px 20px",borderRadius:50,fontSize:12,fontWeight:600,zIndex:9999,boxShadow:"0 8px 30px rgba(0,0,0,.25)",animation:"toastSlide .3s ease",whiteSpace:"nowrap"}}>{toast.m}</div>}
  </div>;
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>
